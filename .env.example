IMMICH_API_URL=http://host.docker.internal:2283/api
IMMICH_API_KEY=replace-with-your-api-key

# Keep this true for the first runs. Change to false only after the dashboard dry scan looks right.
DRY_RUN=true

# Run automatically once per day, ideally while everyone is asleep.
DAILY_SCAN_ENABLED=true
DAILY_SCAN_TIME=02:30
RUN_ON_START=false
TZ=America/Denver

WEB_PORT=8080

JPEG_QUALITY=92
PAGE_SIZE=250
MAX_ASSETS=0
REMOTE_DUPLICATE_CHECK=true
PRESERVE_METADATA=true
